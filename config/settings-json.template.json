{
  "_doc": "Template for ~/.claude/settings.json. Merge the 'hooks' block into your existing settings (keep enabledPlugins, theme, etc.). Replace <USER_HOME_POSIX> with /c/Users/<your-name> on Windows or $HOME on Mac/Linux. The notify-once.ps1 and claude-mem-autopatch.ps1 references assume you set up scripts/ under ~/.claude/ and ~/.lark-cli/daemon/.",

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File '<USER_HOME_POSIX>/.claude/scripts/claude-mem-autopatch.ps1' >/dev/null 2>&1 || true",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File '<USER_HOME_POSIX>/.claude/scripts/claude-agent-sdk-autopatch.ps1' >/dev/null 2>&1 || true",
            "timeout": 20
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -ExecutionPolicy Bypass -File '<USER_HOME>\\.lark-cli\\daemon\\notify-once.ps1' -AutoBot -Text '🔄 session 压缩完成（context reset），Feishu 长连接保持中' -Tag 'postcompact' -MinIntervalSec 30 >/dev/null 2>&1; exit 0",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": []
  },

  "_enabled_plugins_example": {
    "claude-obsidian@claude-obsidian-marketplace": true,
    "claude-mem@thedotmack": true,
    "commit-commands@claude-plugins-official": true,
    "example-skills@anthropic-agent-skills": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true
  },

  "_extra_marketplaces_example": {
    "claude-obsidian-marketplace": {
      "source": {
        "source": "github",
        "repo": "<author>/claude-obsidian"
      }
    }
  },

  "_other_settings_example": {
    "effortLevel": "medium",
    "autoUpdatesChannel": "latest",
    "skipDangerousModePermissionPrompt": true,
    "theme": "dark"
  }
}
